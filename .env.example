BOT_TOKEN=7000000000:AAF...

# Free-first vision provider.
# Create a free key in Google AI Studio, then put it here.
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_VISION_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional. Recommended on shared hosting because anonymous image requests share an IP queue.
# Create a free key at https://enter.pollinations.ai
POLLINATIONS_API_KEY=

# Local docker-compose (default: services 'db' and 'redis' are defined in docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/photo_recipe
REDIS_URL=redis://redis:6379/0

# Production with managed services: replace the two URLs above when deploying.
# Postgres (e.g. Neon, Supabase): use 'postgresql+asyncpg://' and append '?ssl=require'
#   DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST.neon.tech/DB?ssl=require
# Redis (e.g. Upstash): use 'rediss://' for TLS; redis-py handles it natively
#   REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379

RATE_LIMIT_PHOTOS_PER_HOUR=5
CACHE_TTL_SECONDS=86400
IMAGE_CACHE_TTL_SECONDS=604800
